# Kopie als .env.local anlegen und ausfüllen. .env.local ist gitignored.

# Frontend — nur diese beiden Werte sind öffentlich unbedenklich.
VITE_SUPABASE_URL=https://<projekt-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# NIEMALS mit VITE_ prefixen und niemals ins Frontend:
# Diese Keys werden als Secrets in Supabase hinterlegt
# (supabase secrets set ...) und nur in Edge Functions gelesen.
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# ANTHROPIC_API_KEY=<anthropic-key>
# RESEND_API_KEY=<resend-key>
